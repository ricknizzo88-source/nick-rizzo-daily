NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key used by scripts/import-instagram-posts.mjs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Instagram Graph API import settings.
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-business-or-creator-user-id
INSTAGRAM_IMPORT_LIMIT=100
INSTAGRAM_SYNC_LIMIT=25
META_GRAPH_API_VERSION=v23.0

# YouTube Data API settings.
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_CHANNEL_HANDLE=@yourhandle
YOUTUBE_IMPORT_MAX_PAGES=20
YOUTUBE_SHORT_MAX_SECONDS=65

# Optional but recommended for deployment.
# When both are set, /review, /admin/places, and /places/edit require login.
ADMIN_PASSWORD=choose-a-private-password
ADMIN_SESSION_TOKEN=generate-a-long-random-string
